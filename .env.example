# Untuk runtime aplikasi. Pada deployment serverless Supabase, boleh memakai Transaction pooler port 6543.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Untuk Prisma db push/migrate. Gunakan Session pooler port 5432 atau direct connection string Supabase.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_APP_NAME="FasilitasLapor"
PRIORITY_WEIGHT_DAMAGE="10"
PRIORITY_WEIGHT_VALIDATION="1.2"
PRIORITY_WEIGHT_DUPLICATION="3"
PRIORITY_WEIGHT_TIME="0.7"
AUTH_SECRET="ganti-dengan-random-secret-minimal-32-karakter"
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key-jangan-dipublikasi"
SUPABASE_REPORT_PHOTO_BUCKET="report-photos"
